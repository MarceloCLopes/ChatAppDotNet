@page "/"

<div class="joinOuterContainer">
    <div class="joinInnerContainer">
        <h1 class="heading">Join</h1>
        <div>
            <input class="joinInput" placeholder="Name" type="text" @bind="name" />
        </div>
        <div>
            <input class="joinInput mt-20" placeholder="Room" type="text" @bind="room" />
        </div>
        <button class="button mt-20" @onclick="EntrarNoChat">
            Sign In
        </button>
    </div>
</div>

@code {
    private string name = string.Empty;
    private string room = string.Empty;

    private void EntrarNoChat()
    {
        var url = $"/chat?name={Uri.EscapeDataString(name)}&room={Uri.EscapeDataString(room)}";
        Navigation.NavigateTo(url);
    }
}
